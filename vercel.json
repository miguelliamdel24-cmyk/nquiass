{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/img/(.*)",
      "dest": "/img/$1",
      "headers": { "cache-control": "s-maxage=31536000, immutable" }
    },
    {
      "src": "/(.*).js",
      "dest": "/$1.js",
      "headers": { "cache-control": "s-maxage=31536000, immutable" }
    },
    {
      "src": "/(.*).css",
      "dest": "/$1.css",
      "headers": { "cache-control": "s-maxage=31536000, immutable" }
    },
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}